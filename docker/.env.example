# Morgan Docker environment example
# Copy to .env and customize:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Compose ports
# -----------------------------------------------------------------------------
MORGAN_SERVER_PORT=8080
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# Core server flags
# -----------------------------------------------------------------------------
MORGAN_WORKERS=4
MORGAN_LOG_LEVEL=INFO
MORGAN_LOG_FORMAT=json
MORGAN_USER_ID=docker-user

MORGAN_ENABLE_WORKSPACE=true
MORGAN_ENABLE_TOOLS=true
MORGAN_ENABLE_COMPACTION=true
MORGAN_ENABLE_AGENTS=true
MORGAN_ENABLE_SCHEDULING=true
MORGAN_ENABLE_CHANNELS=false

# Optional channels
MORGAN_TELEGRAM_TOKEN=
MORGAN_DISCORD_TOKEN=
MORGAN_SYNOLOGY_TOKEN=
MORGAN_SYNOLOGY_INCOMING_URL=

# -----------------------------------------------------------------------------
# LLM configuration
# -----------------------------------------------------------------------------
# Remote Ollama for primary LLM traffic
MORGAN_LLM_PROVIDER=ollama
MORGAN_LLM_ENDPOINT=http://192.168.100.233:11434
MORGAN_LLM_MODEL=qwen3.5:35b
MORGAN_LLM_API_KEY=ollama-key

# morgan-rag core settings consumed by the assistant internals
LLM_BASE_URL=http://192.168.100.233:11434/v1
LLM_MODEL=qwen3.5:35b
LLM_API_KEY=ollama-key
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Embedding configuration
# -----------------------------------------------------------------------------
# Remote Ollama for smaller-model / embedding traffic
MORGAN_EMBEDDING_PROVIDER=ollama
MORGAN_EMBEDDING_MODEL=qwen3-embedding:latest
MORGAN_EMBEDDING_ENDPOINT=http://192.168.100.222:11434/v1
MORGAN_EMBEDDING_DIMENSIONS=2048

EMBEDDING_BASE_URL=http://192.168.100.222:11434/v1
EMBEDDING_MODEL=qwen3-embedding:latest
EMBEDDING_FORCE_REMOTE=true
OLLAMA_HOST=http://192.168.100.222:11434

# -----------------------------------------------------------------------------
# Redis/cache/session tuning
# -----------------------------------------------------------------------------
MORGAN_CACHE_BACKEND=redis
MORGAN_SESSION_BACKEND=redis
MORGAN_SESSION_TTL=3600

# -----------------------------------------------------------------------------
# Optional model download auth
# -----------------------------------------------------------------------------
HF_TOKEN=

# -----------------------------------------------------------------------------
# Monitoring credentials
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
